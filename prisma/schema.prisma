generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}


// ─── ENUMS ────────────────────────────────────────────────────────────────────


enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ComplaintStatus {
  PENDING
  RESOLVED
  CANCELLED
}

enum LeaveType {
  SICK
  PERSONAL
  EMERGENCY
  OD
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  PASSED_OUT
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

// ─── CHATBOT KNOWLEDGE BASE ──────────────────────────────────────────────────

enum KnowledgeSourceType {
  TEXT
  FILE
  URL
}


// ─── COLLEGE ──────────────────────────────────────────────────────────────────


model College {
  id        String   @id @default(uuid())
  name      String
  domain    String?
  location  String
  createdAt DateTime @default(now())

  admins      Admin[]
  members     AdminMember[]
  students    Student[]
  hostels     Hostel[]
  classes     Class[]
  roles       Role[]
  gallery     Gallery[]
  knowledgeSources  ChatbotKnowledgeSource[]
}


// ─── ADMIN (college owner) ────────────────────────────────────────────────────


model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  collegeId String
  createdAt DateTime @default(now())

  college   College  @relation(fields: [collegeId], references: [id])
}


// ─── ROLES ────────────────────────────────────────────────────────────────────


model Role {
  id        String   @id @default(uuid())
  name      String
  collegeId String
  createdAt DateTime @default(now())

  college     College          @relation(fields: [collegeId], references: [id])
  permissions RolePermission[]
  members     AdminMember[]
}


// ─── ROLE PERMISSIONS ─────────────────────────────────────────────────────────
// One row per module per role.
// module values: "students" | "leaves" | "complaints"


model RolePermission {
  id        String  @id @default(uuid())
  roleId    String
  module    String
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  canApprove Boolean @default(false)

  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
}


// ─── ADMIN MEMBERS (staff) ────────────────────────────────────────────────────
// Staff created by Admin. Access controlled by Role.
// classId / hostelId are optional scope restrictions.


model AdminMember {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  roleId    String
  collegeId String
  classId   String?
  hostelId  String?
  createdAt DateTime @default(now())

  role      Role     @relation(fields: [roleId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])
  class     Class?   @relation(fields: [classId], references: [id])
  hostel    Hostel?  @relation(fields: [hostelId], references: [id])

  assignedLeaves  Leave[] @relation("AssignedTo")
  reviewedLeaves  Leave[] @relation("ReviewedBy")
  facultyStudents StudentFaculty[]
  assignedComplaints Complaint[]
}


// ─── CLASS ────────────────────────────────────────────────────────────────────


model Class {
  id        String   @id @default(uuid())
  name      String
  collegeId String
  createdAt DateTime @default(now())

  college   College       @relation(fields: [collegeId], references: [id])
  students  Student[]
  members   AdminMember[]
}


// ─── HOSTEL ───────────────────────────────────────────────────────────────────


model Hostel {
  id        String   @id @default(uuid())
  name      String
  location  String
  capacity  Int
  collegeId String
  createdAt DateTime @default(now())
  description    String?
  rules          String?
  chatbotContext String?

  college   College       @relation(fields: [collegeId], references: [id])
  students  Student[]
  members   AdminMember[]
}

// ─── CHATBOT KNOWLEDGE BASE ──────────────────────────────────────────────────

model ChatbotKnowledgeSource {
  id          String              @id @default(uuid())
  collegeId   String
  type        KnowledgeSourceType
  label       String
  content     String              @db.Text
  sourceUrl   String?
  fileName    String?
  fileMime    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  college     College             @relation(fields: [collegeId], references: [id])

  @@index([collegeId])
}


// ─── STUDENT ──────────────────────────────────────────────────────────────────


model Student {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  rollNumber  String
  phoneNumber String
  department  String
  year        String
  roomNumber  String?
  bedNumber   String?
  gender      Gender
  parentName  String
  parentContact String
  status      StudentStatus
  profileImage String?
  address     String
  dateOfBirth DateTime
  emergencyContactName String
  emergencyContactNumber String
  bloodGroup  String
  checkInDate DateTime
  checkOutDate DateTime?
  feeStatus   FeeStatus
  passOutYear Int
  inYear      Int
  idCardPdf   String?
  collegeId   String
  classId     String?
  hostelId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  college     College    @relation(fields: [collegeId], references: [id])
  class       Class?     @relation(fields: [classId], references: [id])
  hostel      Hostel?    @relation(fields: [hostelId], references: [id])

  leaves      Leave[]
  complaints  Complaint[]
  reviews     Review[]
  facultyInCharge StudentFaculty[]

  @@index([collegeId])
  @@index([classId])
  @@index([hostelId])
}


// ─── ANNOUNCEMENTS ──────────────────────────────────────────────────────────


model Announcement {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  imageUrl    String?
  imagePublicId String?
  imageWidth  Int?
  imageHeight Int?
  linkUrl     String?
  linkLabel   String?
  postedBy    String
  role        String
  isActive    Boolean  @default(true)
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, createdAt])
  @@index([isPinned, createdAt])
}


// ─── LEAVE ────────────────────────────────────────────────────────────────────


model Leave {
  id           String      @id @default(uuid())
  studentId    String
  collegeId    String

  leaveType    LeaveType   @default(PERSONAL)
  title        String?
  reason       String
  fromDate     DateTime
  toDate       DateTime
  totalDays    Int         @default(1)
  documentUrl  String?
  status       LeaveStatus @default(PENDING)
  assignedToId String?
  reviewedById String?
  reviewedAt   DateTime?
  reviewerComment String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  student      Student      @relation(fields: [studentId], references: [id])
  assignedTo   AdminMember? @relation("AssignedTo", fields: [assignedToId], references: [id])
  reviewedBy   AdminMember? @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([studentId])
  @@index([collegeId])
  @@index([status])
}


// ─── COMPLAINT ────────────────────────────────────────────────────────────────


model Complaint {
  id          String          @id @default(uuid())
  studentId   String
  title       String
  description String
  status      ComplaintStatus @default(PENDING)
  assignedToId String?
  createdAt   DateTime        @default(now())

  student     Student         @relation(fields: [studentId], references: [id])
  assignedTo  AdminMember?    @relation(fields: [assignedToId], references: [id])
}

model StudentFaculty {
  id        String   @id @default(uuid())
  studentId String
  memberId  String
  createdAt DateTime @default(now())

  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  member    AdminMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([studentId, memberId])
}


// ─── REVIEW ───────────────────────────────────────────────────────────────────


model Review {
  id        String   @id @default(uuid())
  studentId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
}


// ─── GALLERY ──────────────────────────────────────────────────────────────────


model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String?
  collegeId String
  createdAt DateTime @default(now())

  college   College  @relation(fields: [collegeId], references: [id])
}
